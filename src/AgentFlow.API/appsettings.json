{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=AgentFlowDb;Trusted_Connection=True;TrustServerCertificate=True;",
    "Redis": "localhost:6379"
  },
  "Anthropic": {
    "ApiKey": "YOUR_ANTHROPIC_API_KEY"
  },
  "Meta": {
    "VerifyToken": "YOUR_META_VERIFY_TOKEN",
    "AppSecret": "YOUR_META_APP_SECRET"
  },
  "UltraMsg": {
    "InstanceId": "YOUR_ULTRAMSG_INSTANCE_ID",
    "Token": "YOUR_ULTRAMSG_TOKEN"
  },
  "AzureBlobStorage": {
    "ConnectionString": "YOUR_AZURE_BLOB_CONNECTION_STRING",
    "ContainerName": "agent-documents"
  },
  "Auth": {
    "Authority": "https://your-auth-server",
    "Audience": "agentflow-api"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
