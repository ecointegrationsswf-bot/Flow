<?xml version="1.0" encoding="utf-8"?>
<!--
  web.config para hosting bajo IIS (site12 en site4future).

  Si NO existe este archivo, "dotnet publish" genera uno default que NO incluye
  <requestLimits maxAllowedContentLength="..."> y IIS aplica su techo de 30 MB,
  que corta los uploads de PDFs de referencia (limite real 100 MB en el código).

  El bloque <aspNetCore> se mantiene minimalista; "dotnet publish" lo respeta
  y deja todo lo que ya teniamos antes.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet" arguments=".\AgentFlow.API.dll" stdoutLogEnabled="false" stdoutLogFile=".\logs\stdout" hostingModel="OutOfProcess" />
      <security>
        <requestFiltering>
          <!-- 100 MB en bytes (104857600). Coordinado con Kestrel.MaxRequestBodySize y [RequestSizeLimit] del controller. -->
          <requestLimits maxAllowedContentLength="104857600" />
        </requestFiltering>
      </security>
    </system.webServer>
  </location>
</configuration>
